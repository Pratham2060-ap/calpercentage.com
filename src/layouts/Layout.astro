---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Online percentage calculators — percentage, discount, tip, and more. Instant results, no ads.",
} = Astro.props;

const nav = [
  { label: "Percentage Calculator",  href: "/percentage-calculator" },
  { label: "Percentage of Number",   href: "/percentage-of-number" },
  { label: "Percentage Change",      href: "/percentage-increase" },
  { label: "Discount",      href: "/discount-calculator" },
  { label: "Tip",           href: "/tip-calculator" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === "Home" ? "Percentage Calculators" : title} | calpercentage.com</title>
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="PercentCalc" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
  <slot name="head" />
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-HKDHEPLWN2" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-HKDHEPLWN2');
  </script>
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark') {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  </script>
</head>

<body class="bg-canvas-soft text-ink antialiased">

  <!-- Navigation -->
  <header class="sticky top-0 z-50 bg-canvas" style="border-bottom:1px solid var(--color-line);">
    <div class="max-w-6xl mx-auto px-5 flex items-center justify-between" style="height:64px;">

      <a href="/" class="text-sm font-semibold text-ink no-underline flex-shrink-0">
        calpercentage<span class="text-muted">.com</span>
      </a>

      <!-- Desktop links -->
      <nav class="hidden md:flex items-center gap-0.5">
        {nav.map(link => (
          <a
            href={link.href}
            class={`px-3 py-1.5 text-sm rounded-full no-underline transition-colors ${
              path === link.href
                ? "bg-canvas-soft-2 text-ink font-medium"
                : "text-secondary hover:text-ink hover:bg-canvas-soft"
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right-side actions -->
      <div class="flex items-center gap-0.5">
        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          class="p-2 rounded-full text-secondary hover:text-ink hover:bg-canvas-soft transition-colors cursor-pointer"
          aria-label="Toggle dark mode"
          style="width:2.25rem; height:2.25rem; display:flex; align-items:center; justify-content:center;"
        >
          <!-- Moon — shown in light mode -->
          <svg id="icon-moon" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <!-- Sun — shown in dark mode -->
          <svg id="icon-sun" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" class="hidden">
            <circle cx="12" cy="12" r="5"/><path stroke-linecap="round" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button id="menu-btn" class="md:hidden p-2 text-ink cursor-pointer" aria-label="Menu">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path id="menu-open"  stroke-linecap="round" d="M3 6h18M3 12h18M3 18h18"/>
            <path id="menu-close" stroke-linecap="round" class="hidden" d="M6 6l12 12M6 18L18 6"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-nav" class="hidden" style="border-top:1px solid var(--color-line); background:var(--color-canvas);">
      <div class="max-w-6xl mx-auto px-5 py-3 flex flex-col gap-0.5">
        {nav.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm rounded-lg no-underline transition-colors ${
              path === link.href
                ? "bg-canvas-soft-2 text-ink font-medium"
                : "text-secondary hover:text-ink hover:bg-canvas-soft"
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="mt-16 sm:mt-24" style="border-top:1px solid var(--color-line); background:var(--color-canvas);">
    <div class="max-w-6xl mx-auto px-5 py-10 md:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">

        <div class="sm:col-span-2 md:col-span-1">
          <a href="/" class="text-sm font-semibold text-ink no-underline">calpercentage.com</a>
          <p class="mt-2 text-sm text-muted leading-5">Percentage calculators. Clean, fast.</p>
        </div>

        <div>
          <p class="form-label mb-3">Calculators</p>
          <div class="flex flex-col gap-2">
            {nav.map(link => (
              <a href={link.href} class="text-sm text-secondary hover:text-ink no-underline transition-colors">{link.label}</a>
            ))}
          </div>
        </div>

        <div>
          <p class="form-label mb-3">Quick Formulas</p>
          <div class="flex flex-col gap-2">
            <a href="/percentage-calculator" class="text-sm text-secondary hover:text-ink no-underline transition-colors">P% of V = ?</a>
            <a href="/percentage-of-number" class="text-sm text-secondary hover:text-ink no-underline transition-colors">X is ?% of Y</a>
            <a href="/percentage-increase" class="text-sm text-secondary hover:text-ink no-underline transition-colors">Percentage change formula</a>
            <a href="/discount-calculator" class="text-sm text-secondary hover:text-ink no-underline transition-colors">Discount formula</a>
          </div>
        </div>

        <div>
          <p class="form-label mb-3">Company</p>
          <div class="flex flex-col gap-2">
            <a href="/about" class="text-sm text-secondary hover:text-ink no-underline transition-colors">About Us</a>
            <a href="/contact" class="text-sm text-secondary hover:text-ink no-underline transition-colors">Contact</a>
            <a href="/privacy-policy" class="text-sm text-secondary hover:text-ink no-underline transition-colors">Privacy Policy</a>
            <a href="/terms" class="text-sm text-secondary hover:text-ink no-underline transition-colors">Terms &amp; Conditions</a>
            <span class="text-sm text-muted mt-2">© {new Date().getFullYear()} calpercentage.com</span>
          </div>
        </div>

      </div>
    </div>
  </footer>

  <script is:inline>
    // Mobile menu
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('mobile-nav');
    const ico = document.getElementById('menu-open');
    const icc = document.getElementById('menu-close');
    btn?.addEventListener('click', () => {
      const open = nav?.classList.toggle('hidden');
      if (open === false) {
        ico?.classList.add('hidden');
        icc?.classList.remove('hidden');
      } else {
        ico?.classList.remove('hidden');
        icc?.classList.add('hidden');
      }
    });

    // Dark mode toggle
    const themeToggle = document.getElementById('theme-toggle');
    const iconMoon = document.getElementById('icon-moon');
    const iconSun  = document.getElementById('icon-sun');

    function syncThemeIcons() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      iconMoon?.classList.toggle('hidden', isDark);
      iconSun?.classList.toggle('hidden', !isDark);
    }
    syncThemeIcons();

    themeToggle?.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
      syncThemeIcons();
    });
  </script>

</body>
</html>
