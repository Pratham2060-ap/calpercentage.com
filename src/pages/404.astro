---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-2xl mx-auto px-5 py-24 sm:py-36 text-center">

    <p class="text-sm font-medium text-muted tracking-widest uppercase mb-6">404</p>

    <h1 class="text-3xl sm:text-4xl font-semibold text-ink mb-4">Page not found</h1>
    <p class="text-base text-secondary mb-10 leading-relaxed">
      The page you're looking for doesn't exist or has been moved.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a href="/" class="btn-primary px-5 py-2.5 text-sm">
        Go to Home
      </a>
      <a href="/percentage-calculator" class="btn-secondary px-5 py-2.5 text-sm">
        Try a Calculator
      </a>
    </div>

    <div class="mt-16 pt-10" style="border-top:1px solid var(--color-line);">
      <p class="text-sm text-muted mb-4">Or jump to one of our calculators:</p>
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/percentage-calculator"  class="tag">Percentage</a>
        <a href="/percentage-of-number"   class="tag">Percentage of Number</a>
        <a href="/percentage-increase"    class="tag">Percentage Change</a>
        <a href="/discount-calculator"    class="tag">Discount</a>
        <a href="/tip-calculator"         class="tag">Tip</a>
      </div>
    </div>

  </section>
</Layout>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-ink);
    color: var(--color-canvas);
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-canvas-soft);
    color: var(--color-ink);
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--color-line);
    transition: background 0.15s;
  }
  .btn-secondary:hover { background: var(--color-canvas-soft-2); }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    color: var(--color-secondary);
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-line);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .tag:hover {
    color: var(--color-ink);
    background: var(--color-canvas-soft-2);
  }
</style>
