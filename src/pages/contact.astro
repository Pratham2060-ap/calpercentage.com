---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us"
  description="Get in touch with calpercentage.com. Report a bug, suggest a new calculator, or send us any feedback."
>
  <section class="max-w-3xl mx-auto px-5 py-16 sm:py-24">

    <p class="form-label mb-4">Contact</p>
    <h1 class="text-3xl sm:text-4xl font-semibold text-ink mb-4" style="letter-spacing:-0.05em; line-height:1.1;">
      Get in touch.
    </h1>
    <p class="text-base sm:text-lg text-secondary leading-7 mb-12 max-w-md">
      Found a bug? Have a suggestion for a new calculator? We're happy to hear from you.
    </p>

    <div style="border-top:1px solid var(--color-line); padding-top:3rem;">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
        {[
          { icon: "🐛", title: "Report a bug", body: "Something calculating incorrectly or a broken UI? Let us know the page and the inputs you used." },
          { icon: "💡", title: "Suggest a tool", body: "Have a percentage problem we don't cover yet? Tell us and we'll consider adding it." },
          { icon: "📝", title: "General feedback", body: "Anything else — design suggestions, usability improvements, or just to say hi." },
          { icon: "🤝", title: "Business enquiries", body: "For partnerships, content collaborations, or other business matters." },
        ].map(item => (
          <div class="card flex gap-3">
            <span class="text-xl mt-0.5">{item.icon}</span>
            <div>
              <p class="text-sm font-semibold text-ink mb-1">{item.title}</p>
              <p class="text-sm text-secondary leading-5">{item.body}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Contact form -->
      <div class="card">
        <h2 class="text-lg font-semibold text-ink mb-6" style="letter-spacing:-0.02em;">Send a message</h2>

        <form
          id="contact-form"
          class="space-y-5"
          novalidate
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="form-label block mb-1.5">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Your name"
                required
                class="form-input w-full"
              />
            </div>
            <div>
              <label for="email" class="form-label block mb-1.5">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                required
                class="form-input w-full"
              />
            </div>
          </div>

          <div>
            <label for="subject" class="form-label block mb-1.5">Subject</label>
            <select id="subject" name="subject" class="form-input w-full">
              <option value="bug">Report a bug</option>
              <option value="suggestion">Suggest a tool</option>
              <option value="feedback">General feedback</option>
              <option value="business">Business enquiry</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="form-label block mb-1.5">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              placeholder="Describe your question or feedback..."
              required
              class="form-input w-full resize-none"
            ></textarea>
          </div>

          <div class="flex items-center gap-4">
            <button type="submit" class="btn-primary" id="submit-btn">Send message</button>
            <p id="form-status" class="text-sm text-secondary hidden"></p>
          </div>
        </form>
      </div>

    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();

      if (!name || !email || !message) {
        status.textContent = 'Please fill in all required fields.';
        status.classList.remove('hidden', 'text-secondary');
        status.classList.add('text-red-500');
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        status.textContent = 'Please enter a valid email address.';
        status.classList.remove('hidden', 'text-secondary');
        status.classList.add('text-red-500');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      status.classList.add('hidden');

      await new Promise(r => setTimeout(r, 800));

      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
      status.textContent = 'Message sent! We\'ll get back to you soon.';
      status.classList.remove('hidden', 'text-red-500');
      status.classList.add('text-secondary');
      form.reset();
    });
  </script>
</Layout>
