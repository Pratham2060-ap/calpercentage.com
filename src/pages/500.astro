---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Server Error" description="Something went wrong on our end.">
  <section class="max-w-2xl mx-auto px-5 py-24 sm:py-36 text-center">

    <p class="text-sm font-medium text-muted tracking-widest uppercase mb-6">500</p>

    <h1 class="text-3xl sm:text-4xl font-semibold text-ink mb-4">Something went wrong</h1>
    <p class="text-base text-secondary mb-10 leading-relaxed">
      We're having trouble on our end. Please try again in a moment.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <button onclick="window.location.reload()" class="btn-primary px-5 py-2.5 text-sm cursor-pointer">
        Try Again
      </button>
      <a href="/" class="btn-secondary px-5 py-2.5 text-sm">
        Go to Home
      </a>
    </div>

  </section>
</Layout>

<style>
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-ink);
    color: var(--color-canvas);
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    border: none;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.85; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-canvas-soft);
    color: var(--color-ink);
    border-radius: 0.5rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--color-line);
    transition: background 0.15s;
  }
  .btn-secondary:hover { background: var(--color-canvas-soft-2); }
</style>
